{
    "name": "ayudita/api",
    "description": "API REST de Ayudita - plataforma de contratación temporal de servicios (PHP 8 puro, sin frameworks)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-fileinfo": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
