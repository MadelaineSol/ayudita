# ---------------------------------------------------------
# Ayudita API - Variables de entorno
# Copiar a .env y completar. NUNCA subir .env al repositorio.
# ---------------------------------------------------------

APP_URL=https://api.ayudita.app
APP_DEBUG=false

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ayudita
DB_USER=ayudita_user
DB_PASS=

# Generar con: php -r "echo bin2hex(random_bytes(48));"
JWT_SECRET=
JWT_TTL=900
REFRESH_TTL_DAYS=30

# Orígenes permitidos, separados por coma.
# Incluir el origen de Capacitor para la app móvil.
CORS_ORIGINS=https://ayudita.app,https://admin.ayudita.app,https://localhost,capacitor://localhost,http://localhost
